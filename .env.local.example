# App
NEXT_PUBLIC_APP_URL=https://reuniai.vercel.app
# Fallback genérico do nome do bot (opcional). NÃO sobrescreve o nome personalizado:
# o bot sempre prioriza "ReuniAI - {nome do usuário}". Use só para contextos sem usuário.
# NEXT_PUBLIC_BOT_NAME=ReuniAI Bot

# Branding do bot nas calls. IMPORTANTE: precisam ser URLs PÚBLICAS que a Vexa Cloud
# consiga baixar — localhost NÃO funciona. Em produção (Vercel), as imagens são geradas
# automaticamente em /brand/bot-background.png e /brand/bot-camera.png. Em dev local,
# hospede os PNGs (ex.: bucket público do Supabase Storage) e aponte aqui, ou use a URL
# do deploy de preview/produção. Se vazio, usa NEXT_PUBLIC_APP_URL/brand/*.
# BOT_AVATAR_URL=https://SEU-DOMINIO-PUBLICO/brand/bot-background.png
# BOT_SCREEN_URL=https://SEU-DOMINIO-PUBLICO/brand/bot-background.png

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (calendar tokens)
ENCRYPTION_KEY=

# Google Calendar (separado do Supabase Google OAuth)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft / Outlook Calendar + Teams transcripts (Onda 16)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_WEBHOOK_SECRET=
MICROSOFT_WEBHOOK_CLIENT_STATE=

# Vexa (bot de reunião + transcrição Whisper)
VEXA_API_BASE=https://api.cloud.vexa.ai
VEXA_API_KEY=
VEXA_WEBHOOK_SECRET=

# Recall.ai (legado — não usado; substituído por Vexa)
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=

# Deepgram (legado — não usado; transcrição via Vexa/Whisper)
DEEPGRAM_API_KEY=

# LLM — provedor resolvido por LLM_PROVIDER ou primeira chave disponível (groq > openai > anthropic)
LLM_PROVIDER=groq
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Embeddings para RAG (opcional — OpenAI-compatible API; sem chave usa transcrição completa)
EMBEDDINGS_API_KEY=
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_API_BASE=https://api.openai.com/v1

# Slack (opcional)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion (opcional)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

CRON_SECRET=

# Email (opcional)
RESEND_API_KEY=
RESEND_FROM=ReuniAI <onboarding@resend.dev>

# Web Push (opcional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@reuniai.app
